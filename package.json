{
  "name": "obsidian-pubcopy",
  "version": "1.2.0",
  "description": "Copy Obsidian notes as platform-optimized HTML for Medium and Substack",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "npm run build && node deploy.mjs",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cli": "bash tests/cli/run-cli-tests.sh",
    "docs": "typedoc --entryPoints src/main.ts src/converter/index.ts src/platforms/index.ts src/settings.ts src/clipboard/writer.ts src/utils/errors.ts src/utils/html.ts --out docs --tsconfig tsconfig.json --skipErrorChecking",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "medium",
    "substack",
    "clipboard",
    "html",
    "publish"
  ],
  "author": "canartuc",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "jsdom": "^29.0.1",
    "obsidian": "^1.12.0",
    "tslib": "^2.7.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "katex": "^0.16.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "unified": "^11.0.0"
  }
}
